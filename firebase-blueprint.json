{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["super-admin", "admin", "lead", "member"] },
        "teamId": { "type": "string" },
        "teamIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "canCreateMultipleTeams": { "type": "boolean" }
      },
      "required": ["uid", "email", "role"]
    },
    "Team": {
      "title": "Team",
      "description": "Team information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "leadId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "leadId"]
    },
    "Task": {
      "title": "Task",
      "description": "A productivity task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "completed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "assigneeId": { "type": "string" },
        "assigneeIds": { "type": "array", "items": { "type": "string" } },
        "completedBy": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" },
        "teamId": { "type": "string" },
        "timeSpent": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "priority"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Short-term or long-term goal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["short-term", "long-term"] },
        "targetDate": { "type": "string", "format": "date-time" },
        "progress": { "type": "number" },
        "userId": { "type": "string" },
        "teamId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "targetDate"]
    },
    "TimeLog": {
      "title": "Time Log",
      "description": "Tracking time spent on a task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" }
      },
      "required": ["taskId", "userId", "startTime"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Message in team chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teamId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["teamId", "senderId", "message"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and suggestions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message"]
    },
    "TeamDataRecord": {
      "title": "Team Data Record",
      "description": "A single record of team data",
      "type": "object",
      "properties": {
        "teamId": { "type": "string" },
        "batchId": { "type": "string" },
        "sheetName": { "type": "string" },
        "assignedUserId": { "type": "string" },
        "assignedUserIds": { "type": "array", "items": { "type": "string" } },
        "editorIds": { "type": "array", "items": { "type": "string" } },
        "viewerIds": { "type": "array", "items": { "type": "string" } },
        "dataFields": { "type": "object" },
        "status": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teamId", "sheetName", "status"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Log of team activities",
      "type": "object",
      "properties": {
        "teamId": { "type": "string" },
        "action": { "type": "string", "enum": ["upload", "assignment", "update"] },
        "details": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["teamId", "action", "userId"]
    },
    "ReportTemplate": {
      "title": "Report Template",
      "description": "Saved filter configuration for reports",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "teamId": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "filters": { "type": "object" },
        "columns": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "teamId", "createdBy"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or task notification for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["task_assigned", "task_updated", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string" }
      },
      "required": ["userId", "title", "message", "type", "read"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Team data"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Goals"
    },
    "/timeLogs/{logId}": {
      "schema": "TimeLog",
      "description": "Time logs"
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Chat messages"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback"
    },
    "/team_data/{recordId}": {
      "schema": "TeamDataRecord",
      "description": "Team data records"
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Activity logs"
    },
    "/report_templates/{templateId}": {
      "schema": "ReportTemplate",
      "description": "Saved report templates"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
