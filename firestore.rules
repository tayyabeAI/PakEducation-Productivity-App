rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, teamId, createdAt, lastLogin, canCreateMultipleTeams
    //
    // Collection: teams
    // Fields: id, name, leadId, createdAt
    //
    // Collection: tasks
    // Fields: id, title, description, status, priority, dueDate, assigneeId, assigneeIds, completedBy, completedAt, teamId, timeSpent, createdAt
    //
    // Collection: goals
    // Fields: id, title, description, type, targetDate, progress, userId, teamId, createdAt
    //
    // Collection: timeLogs
    // Fields: id, taskId, userId, startTime, endTime, duration
    //
    // Collection: chats
    // Fields: id, teamId, senderId, senderName, message, timestamp
    //
    // Collection: feedback
    // Fields: id, userId, message, timestamp
    //
    // Collection: activity_logs
    // Fields: teamId, action, details, userId, userName, timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "masnoezahanat@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin')));
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "masnoezahanat@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super-admin'));
    }
    
    function isTeamLead(teamId) {
      return isAuthenticated() && teamId != null && 
             exists(/databases/$(database)/documents/teams/$(teamId)) && 
             get(/databases/$(database)/documents/teams/$(teamId)).data.leadId == request.auth.uid;
    }

    function isTeamMember(teamId) {
      return isAuthenticated() && teamId != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId == teamId ||
              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamIds is list && 
               teamId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamIds));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.email is string &&
             data.role in ['admin', 'lead', 'member'];
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'priority']) &&
             data.title is string && data.title.size() < 200 &&
             data.status in ['todo', 'in-progress', 'completed', 'deleted'] &&
             data.priority in ['low', 'medium', 'high'];
    }

    function isValidReportTemplate(data) {
      return data.keys().hasAll(['name', 'teamId', 'createdBy']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.teamId is string && data.createdBy is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isOwner(userId) || 
        isSuperAdmin() ||
        (resource.data.email == request.auth.token.email) ||
        (resource.data.teamId != null && resource.data.teamId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamIds)
      );
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if (isOwner(userId) && 
                       request.resource.data.role == resource.data.role && 
                       (!('canCreateMultipleTeams' in request.resource.data) || request.resource.data.canCreateMultipleTeams == resource.data.canCreateMultipleTeams) &&
                       (!('teamIds' in request.resource.data) || request.resource.data.teamIds is list)) || 
                       isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /teams/{teamId} {
      allow read: if isSuperAdmin() || 
                    (isAuthenticated() && (resource.data.leadId == request.auth.uid || 
                     teamId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamIds));
      allow create: if isAuthenticated();
      allow update: if isTeamLead(teamId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isSuperAdmin() || 
                    (isAuthenticated() && (
                      (resource.data.teamId != null && resource.data.teamId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamIds) ||
                      resource.data.assigneeId == request.auth.uid ||
                      (request.auth.uid in resource.data.assigneeIds)
                    ));
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && isValidTask(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /goals/{goalId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /timeLogs/{logId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /invitations/{inviteId} {
      allow read: if isAuthenticated() && (request.auth.token.email == resource.data.email || isTeamLead(resource.data.teamId) || isAdmin());
      allow create: if isAuthenticated() && (isTeamLead(request.resource.data.teamId) || isAdmin());
      allow update: if isAuthenticated() && (request.auth.token.email == resource.data.email || isTeamLead(resource.data.teamId) || isAdmin());
      allow delete: if isAuthenticated() && (isTeamLead(resource.data.teamId) || isAdmin());
    }

    match /team_data/{recordId} {
      allow read: if isSuperAdmin() || 
                    (isAuthenticated() && (
                      isTeamMember(resource.data.teamId) && (isTeamLead(resource.data.teamId) || isAdmin()) ||
                      (resource.data.assignedUserId == request.auth.uid) ||
                      (request.auth.uid in resource.data.get('assignedUserIds', [])) ||
                      (request.auth.uid in resource.data.get('editorIds', [])) ||
                      (request.auth.uid in resource.data.get('viewerIds', [])) ||
                      (isTeamMember(resource.data.teamId) && (!('assignedUserId' in resource.data) || resource.data.assignedUserId == null))
                    ));
      allow create: if isAuthenticated() && (isSuperAdmin() || isTeamLead(request.resource.data.teamId) || isAdmin());
      allow update: if isSuperAdmin() || 
                    (isAuthenticated() && (
                      isTeamLead(resource.data.teamId) || 
                      isAdmin() ||
                      resource.data.assignedUserId == request.auth.uid ||
                      (request.auth.uid in resource.data.get('assignedUserIds', [])) ||
                      (request.auth.uid in resource.data.get('editorIds', []))
                    ));
      allow delete: if isSuperAdmin() || isTeamLead(resource.data.teamId) || isAdmin();
    }
    
    match /activity_logs/{logId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.teamId != null && isTeamMember(resource.data.teamId));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /report_templates/{templateId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && isTeamMember(resource.data.teamId));
      allow create: if isAuthenticated() && isValidReportTemplate(request.resource.data) && (isTeamLead(request.resource.data.teamId) || isAdmin());
      allow update: if isAuthenticated() && isValidReportTemplate(request.resource.data) && (isTeamLead(resource.data.teamId) || isAdmin());
      allow delete: if isAuthenticated() && (isTeamLead(resource.data.teamId) || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
