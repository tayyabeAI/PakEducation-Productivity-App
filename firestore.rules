rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, teamId, createdAt
    //
    // Collection: teams
    // Fields: id, name, leadId, createdAt
    //
    // Collection: tasks
    // Fields: id, title, description, status, priority, dueDate, assigneeId, teamId, timeSpent, createdAt
    //
    // Collection: goals
    // Fields: id, title, description, type, targetDate, progress, userId, teamId, createdAt
    //
    // Collection: timeLogs
    // Fields: id, taskId, userId, startTime, endTime, duration
    //
    // Collection: chats
    // Fields: id, teamId, senderId, senderName, message, timestamp
    //
    // Collection: feedback
    // Fields: id, userId, message, timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "masnoezahanat@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isTeamLead(teamId) {
      return isAuthenticated() && teamId != null && 
             exists(/databases/$(database)/documents/teams/$(teamId)) && 
             get(/databases/$(database)/documents/teams/$(teamId)).data.leadId == request.auth.uid;
    }

    function isTeamMember(teamId) {
      return isAuthenticated() && teamId != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId == teamId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.email is string &&
             data.role in ['admin', 'lead', 'member'];
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'priority']) &&
             data.title is string && data.title.size() < 200 &&
             data.status in ['todo', 'in-progress', 'completed', 'deleted'] &&
             data.priority in ['low', 'medium', 'high'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isTeamLead(teamId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if isAuthenticated() && isValidTask(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /goals/{goalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /timeLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /invitations/{inviteId} {
      allow read: if isAuthenticated() && (request.auth.token.email == resource.data.email || isTeamLead(resource.data.teamId) || isAdmin());
      allow create: if isAuthenticated() && (isTeamLead(request.resource.data.teamId) || isAdmin());
      allow update: if isAuthenticated() && (request.auth.token.email == resource.data.email || isTeamLead(resource.data.teamId) || isAdmin());
      allow delete: if isAuthenticated() && (isTeamLead(resource.data.teamId) || isAdmin());
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
